{
    "name": "aura-archive-server",
    "version": "1.0.0",
    "description": "AURA ARCHIVE - Luxury Resell Fashion E-commerce Platform (Backend API)",
    "main": "server.js",
    "type": "commonjs",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "seed": "node src/utils/seeder.js",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:seed": "npx sequelize-cli db:seed:all",
        "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix"
    },
    "dependencies": {
        "@google/genai": "^1.46.0",
        "@google/generative-ai": "^0.24.1",
        "adm-zip": "^0.5.17",
        "axios": "^1.13.2",
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.9.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.1",
        "express-rate-limit": "^7.4.1",
        "express-validator": "^7.2.0",
        "google-auth-library": "^10.5.0",
        "google-translate-api-x": "^10.7.2",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^6.9.16",
        "openai": "^6.32.0",
        "pg": "^8.13.1",
        "pg-hstore": "^2.3.4",
        "resend": "^6.9.4",
        "sequelize": "^6.37.5",
        "socket.io": "^4.8.3",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^11.0.3",
        "winston": "^3.15.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.2.0",
        "eslint": "^9.14.0",
        "nodemon": "^3.1.7",
        "sequelize-cli": "^6.6.2"
    }
}
