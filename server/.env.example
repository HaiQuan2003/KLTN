# Server Environment Variables

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aura_archive
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (SMTP - Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=AURA ARCHIVE <noreply@auraarchive.com>
ADMIN_EMAIL=admin@auraarchive.com

# AI Stylist (integrated — runs inside server)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHATBOT_MODE=auto

# API Docs
# full   = show all routes, including protected/admin routes
# public = show public/demo-safe routes only
# off    = disable /docs and /openapi.json
API_DOCS_MODE=full

# Set to false to disable Swagger "Try it out" buttons
API_DOCS_TRY_IT_OUT=true
